# Koyeb-optimized Dockerfile — Lightweight API Only
# Uses requirements-deploy.txt (no torch/gudhi/matplotlib)
# Resulting image: ~300MB vs ~4.5GB with full requirements

FROM python:3.10-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install only build essentials needed for scipy/scikit-learn wheels
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install lightweight dependencies (no torch, no CUDA)
COPY requirements-deploy.txt .
RUN pip install --no-cache-dir -r requirements-deploy.txt

# Copy only what the API runtime needs
COPY src/ src/

# Copy checkpoint if it exists (using wildcard makes it optional so build doesn't fail)
COPY checkpoints/best_ppo_light.np[z] checkpoints/

# Koyeb assigns PORT dynamically
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:' + __import__('os').getenv('PORT', '8000') + '/api/health')" || exit 1

# Use $PORT from Koyeb, fallback to 8000
CMD uvicorn src.api.main:app --host 0.0.0.0 --port ${PORT:-8000} --proxy-headers
